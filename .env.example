# Vorlage fuer lokale Umgebungsvariablen.
# Kopieren nach ".env" (nicht versioniert) und mit echten Werten befuellen.
# Diese Datei selbst enthaelt KEINE echten Zugangsdaten und darf versioniert werden.

# Umgebung: development | test | production
ENVIRONMENT=development

# Alpaca Paper-Trading API (Aktien-Marktdaten)
# Nur Paper-Trading-Schluessel verwenden, niemals Live-Schluessel in dieser Phase.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Binance Public API (Krypto-Marktdaten)
# Fuer reine Marktdaten-Abfragen ist kein Schluessel zwingend erforderlich.
# Falls ein Konto verwendet wird (hoehere Rate-Limits), Schluessel hier eintragen.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Datenbank
DATABASE_PATH=data/laufzeit/tradingbot.db
